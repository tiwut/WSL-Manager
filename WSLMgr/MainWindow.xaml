<Window x:Class="WSLMgr.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WSL Manager"
        Height="650" Width="980"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource CustomWindowStyle}">

    <Window.Resources>

        <Style x:Key="SidebarTabStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="GroupName" Value="SidebarNav"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="Transparent" BorderThickness="4,0,0,0" Padding="20,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Path x:Name="icon" Grid.Column="0" Data="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                      Fill="{TemplateBinding Foreground}" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/>

                                <ContentPresenter Grid.Column="1" VerticalAlignment="Center" Margin="5,0,0,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E293B"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#172238"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="icon" Property="Fill" Value="{StaticResource AccentLightBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="{StaticResource CardBgBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Placement" Value="Top"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>


        <Border Grid.Column="0" Background="#0B0F19" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>


                <StackPanel Grid.Row="0" Margin="20,25,20,25">
                    <TextBlock Text="WSL DISTROS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock Text="DistroShelf" FontSize="22" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                </StackPanel>


                <StackPanel Grid.Row="1">

                    <RadioButton Content="Dashboard" Style="{StaticResource SidebarTabStyle}"
                                 Tag="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"
                                 IsChecked="True" Checked="Nav_Checked" x:Name="RadDashboard"/>


                    <RadioButton Content="Install / Import" Style="{StaticResource SidebarTabStyle}"
                                 Tag="M19.35 10.04C18.67 6.59 15.64 4 12 4 9.11 4 6.6 5.64 5.35 8.04 2.34 8.36 0 10.91 0 14c0 3.31 2.69 6 6 6h13c2.76 0 5-2.24 5-5 0-2.64-2.05-4.78-4.65-4.96zM17 13l-5 5-5-5h3V9h4v4h3z"
                                 Checked="Nav_Checked" x:Name="RadInstall"/>


                    <RadioButton Content="WSL Config" Style="{StaticResource SidebarTabStyle}"
                                 Tag="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"
                                 Checked="Nav_Checked" x:Name="RadSettings"/>


                    <RadioButton Content="System Doctor" Style="{StaticResource SidebarTabStyle}"
                                 Tag="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2.07-7.75l-.9.92C13.45 12.9 13 13.5 13 15h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2s-2 .9-2 2H7c0-2.76 2.24-5 5-5s5 2.24 5 5c0 1.04-.42 1.99-1.07 2.75z"
                                 Checked="Nav_Checked" x:Name="RadSetup"/>
                </StackPanel>


                <StackPanel Grid.Row="2" Margin="20">
                    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,15,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="GLOBAL STATUS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock x:Name="TxtDistrosCount" Text="0 Distros Installed" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}" Padding="6" Height="28" Width="28" ToolTip="Shutdown All WSL distros" Click="BtnShutdownWSL_Click">

                                <Path Data="M12 2h-1c-.55 0-1 .45-1 1v6c0 .55.45 1 1 1h1c.55 0 1-.45 1-1V3c0-.55-.45-1-1-1zm6.36 4.36l-.7.7a1 1 0 00-.03 1.38C19.14 9.94 19.8 12.01 19.38 14.2c-.59 3.09-3.15 5.56-6.26 6-4 .58-7.55-2.22-7.55-6.2 0-2.3 1.09-4.34 2.8-5.65.37-.28.43-.8.14-1.16l-.68-.86c-.34-.43-.99-.46-1.37-.07C4.16 8.52 2.7 11.59 3 15.06c.46 5.41 4.79 9.8 10.2 10.29 6.46.59 11.8-4.5 11.8-10.85 0-3.32-1.39-6.32-3.64-8.48-.38-.37-1.02-.32-1.36.08z"
                                      Fill="{StaticResource DangerBrush}" Stretch="Uniform"/>
                            </Button>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>


        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>


            <Grid Grid.Row="0" Margin="25,20,25,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtHeaderTitle" Text="Distro Dashboard" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>


                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource SecondaryButtonStyle}" Padding="12,8" Content="Refresh" Click="BtnRefresh_Click">
                        <Button.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"
                                          Fill="White" Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Refresh" VerticalAlignment="Center" FontSize="12"/>
                                </StackPanel>
                            </DataTemplate>
                        </Button.ContentTemplate>
                    </Button>
                </StackPanel>
            </Grid>


            <TabControl Grid.Row="1" x:Name="TabMain" Background="Transparent" BorderThickness="0" Padding="0" Margin="0">
                <TabControl.ItemContainerStyle>
                    <Style TargetType="TabItem">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </Style>
                </TabControl.ItemContainerStyle>


                <TabItem>
                    <Grid Margin="25,10,25,25">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>


                        <Grid Grid.Row="0" Margin="0,0,0,20">
                            <TextBox x:Name="TxtSearch" FontSize="14" Height="40" Padding="35,10,12,10" SelectionBrush="{StaticResource AccentBrush}" TextChanged="TxtSearch_TextChanged"/>

                            <Path Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"
                                  Fill="{StaticResource TextSecondaryBrush}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                            <TextBlock Text="Filter distributions..." Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="37,0,0,0" IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=TxtSearch}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>


                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <Grid>

                                <StackPanel x:Name="PnlEmptyState" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,40,0,0" Visibility="Collapsed">

                                    <Path Data="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm-8 12.25L5.75 10H8.5V8h7v2h2.75L12 16.25z"
                                          Fill="{StaticResource TextMutedBrush}" Width="60" Height="60" Stretch="Uniform" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                                    <TextBlock Text="No WSL Distributions Installed" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="You can download official distros from the catalog or import custom rootfs packages." FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,5,0,20" TextAlignment="Center" MaxWidth="350"/>
                                    <Button Content="Go to Installer Catalog" Style="{StaticResource PrimaryButtonStyle}" HorizontalAlignment="Center" Click="BtnGoToInstaller_Click"/>
                                </StackPanel>


                                <ItemsControl x:Name="ItemsDistros">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" ItemWidth="350" Margin="0,0,-15,0"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,15,15" Padding="15">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>


                                                    <Grid Grid.Row="0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>


                                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="16" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>

                                                            <Border Background="#1E3A8A" BorderBrush="#3B82F6" BorderThickness="1" CornerRadius="4" Margin="10,0,0,0" Padding="5,1,5,2" VerticalAlignment="Center" Visibility="{Binding IsDefault, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                                <TextBlock Text="DEFAULT" FontSize="9" FontWeight="Bold" Foreground="#93C5FD"/>
                                                            </Border>
                                                        </StackPanel>


                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <Ellipse Width="8" Height="8" Fill="{Binding StatusColor}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                            <TextBlock Text="{Binding State}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Grid>


                                                    <TextBlock Grid.Row="1" Text="{Binding DisplayVersion}" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,2,0,12"/>


                                                    <StackPanel Grid.Row="2" Margin="0,0,0,15">

                                                        <Grid Margin="0,0,0,5">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="70"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="Location:" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding BasePath}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" ToolTip="{Binding BasePath}"/>
                                                        </Grid>


                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="70"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="GUID:" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding Guid}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Guid}"/>
                                                        </Grid>
                                                    </StackPanel>


                                                    <Border Grid.Row="3" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,12,0,0">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>


                                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                                <Button Content="Launch" Style="{StaticResource PrimaryButtonStyle}" Padding="15,6" Click="BtnLaunchDistro_Click" Tag="{Binding Name}" Margin="0,0,8,0"/>
                                                                <Button Content="Stop" Style="{StaticResource SecondaryButtonStyle}" Padding="12,6" Click="BtnStopDistro_Click" Tag="{Binding Name}" Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                            </StackPanel>


                                                            <StackPanel Grid.Column="1" Orientation="Horizontal">

                                                                <Button Style="{StaticResource SecondaryButtonStyle}" Padding="6" Height="28" Width="28" Click="BtnSetDefault_Click" Tag="{Binding Name}" ToolTip="Set as Default Distro" IsEnabled="{Binding IsDefault, Converter={StaticResource InverseBooleanConverter}}" Margin="5,0,0,0">
                                                                    <Path Data="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" Fill="{StaticResource TextSecondaryBrush}" Stretch="Uniform"/>
                                                                </Button>

                                                                <Button Style="{StaticResource SecondaryButtonStyle}" Padding="6" Height="28" Width="28" Click="BtnRunCommand_Click" Tag="{Binding Name}" ToolTip="Run Custom Command" Margin="5,0,0,0">
                                                                    <Path Data="M20 4H4c-1.11 0-2 .9-2 2v12c0 1.1.89 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm-8 12H6v-2h6v2zm8-4h-8v-2h8v2zm0-4H6V6h14v2z" Fill="{StaticResource TextSecondaryBrush}" Stretch="Uniform"/>
                                                                </Button>

                                                                <Button Style="{StaticResource SecondaryButtonStyle}" Padding="6" Height="28" Width="28" Click="BtnCloneDistro_Click" Tag="{Binding Name}" ToolTip="Clone/Duplicate Distro" Margin="5,0,0,0">
                                                                    <Path Data="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z" Fill="{StaticResource TextSecondaryBrush}" Stretch="Uniform"/>
                                                                </Button>

                                                                <Button Style="{StaticResource SecondaryButtonStyle}" Padding="6" Height="28" Width="28" Click="BtnExportDistro_Click" Tag="{Binding Name}" ToolTip="Export Distro to .tar" Margin="5,0,0,0">
                                                                    <Path Data="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z" Fill="{StaticResource TextSecondaryBrush}" Stretch="Uniform"/>
                                                                </Button>

                                                                <Button Style="{StaticResource SecondaryButtonStyle}" Padding="6" Height="28" Width="28" Click="BtnExploreFiles_Click" Tag="{Binding Name}" ToolTip="Explore WSL filesystem in Windows Explorer" Margin="5,0,0,0">
                                                                    <Path Data="M20 6h-8l-2-2H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-6 10H6v-2h8v2zm4-4H6v-2h12v2z" Fill="{StaticResource TextSecondaryBrush}" Stretch="Uniform"/>
                                                                </Button>

                                                                <Button Style="{StaticResource DangerButtonStyle}" Padding="6" Height="28" Width="28" Click="BtnDeleteDistro_Click" Tag="{Binding Name}" ToolTip="Delete/Unregister Distro" Margin="5,0,0,0">
                                                                    <Path Data="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" Fill="{StaticResource DangerBrush}" Stretch="Uniform"/>
                                                                </Button>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </TabItem>


                <TabItem>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="25,10,25,25">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>


                            <Border Grid.Row="0" Margin="0,0,0,15" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="DOWNLOAD &amp; INSTALL CATALOG" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AccentLightBrush}"/>
                                    <TextBlock Text="Official WSL Distributions" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,0"/>
                                    <TextBlock Text="Selecting Install will open a console terminal window. Please provide your Unix credentials inside that console window when prompted." FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>


                            <ItemsControl Grid.Row="1" x:Name="ItemsOnlineCatalog" Margin="0,0,0,30">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" ItemWidth="230" Margin="0,0,-15,0"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,15,15" Padding="15">
                                            <Grid Height="100">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <StackPanel Grid.Row="0">
                                                    <TextBlock Text="{Binding FriendlyName}" FontWeight="Bold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Name}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <Button Grid.Row="1" Content="{Binding StatusText}" Style="{StaticResource PrimaryButtonStyle}" Height="30" Padding="10,0" Click="BtnInstallOnline_Click" Tag="{Binding Name}" IsEnabled="{Binding IsInstalled, Converter={StaticResource InverseBooleanConverter}}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>


                            <Border Grid.Row="2" Margin="0,10,0,15" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="IMPORT CUSTOM ROOTFS" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AccentLightBrush}"/>
                                    <TextBlock Text="Create Distro from .tar / .tar.gz" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,0"/>
                                    <TextBlock Text="Import a pre-packaged filesystem backup or download customized roots from sources like Linux Containers." FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>


                            <Border Grid.Row="3" Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>


                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,15,15">
                                        <TextBlock Text="New Distribution Name" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,5"/>
                                        <TextBox x:Name="TxtImportName" FontSize="14" Height="40" VerticalContentAlignment="Center" TextChanged="TxtImportName_TextChanged"/>
                                    </StackPanel>


                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="15,0,0,15">
                                        <TextBlock Text="WSL Version Target" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,5"/>
                                        <ComboBox x:Name="CboImportWslVer" FontSize="14" Height="40" VerticalContentAlignment="Center" SelectedIndex="1">
                                            <ComboBoxItem Content="WSL 1"/>
                                            <ComboBoxItem Content="WSL 2"/>
                                        </ComboBox>
                                    </StackPanel>


                                    <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Margin="0,0,0,15">
                                        <TextBlock Text="Source Tarball (.tar / .tar.gz)" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,5"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="TxtImportTarPath" Grid.Column="0" FontSize="14" Height="40" VerticalContentAlignment="Center" IsReadOnly="True"/>
                                            <Button x:Name="BtnBrowseTar" Grid.Column="1" Content="Select Tarball..." Style="{StaticResource SecondaryButtonStyle}" Margin="10,0,0,0" Height="40" Padding="15,0" Click="BtnBrowseTar_Click"/>
                                        </Grid>
                                    </StackPanel>


                                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,0,0,20">
                                        <TextBlock Text="Install Directory (Destination)" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,5"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="TxtImportDestDir" Grid.Column="0" FontSize="14" Height="40" VerticalContentAlignment="Center" IsReadOnly="True"/>
                                            <Button x:Name="BtnBrowseDestDir" Grid.Column="1" Content="Select Folder..." Style="{StaticResource SecondaryButtonStyle}" Margin="10,0,0,0" Height="40" Padding="15,0" Click="BtnBrowseDestDir_Click"/>
                                        </Grid>
                                    </StackPanel>


                                    <Button Grid.Row="3" Grid.ColumnSpan="2" Content="Import Rootfs Package" Style="{StaticResource PrimaryButtonStyle}" Height="45" FontSize="15" Click="BtnImportDistro_Click"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </TabItem>


                <TabItem>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="25,10,25,25">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>


                            <Border Grid.Row="0" Margin="0,0,0,15" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="WSL ENGINE CONFIGURATION" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AccentLightBrush}"/>
                                    <TextBlock Text="Global WSL Settings Editor" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,0"/>
                                    <TextBlock Text="This tab configures global settings saved in %USERPROFILE%\.wslconfig. These settings apply to all WSL 2 distributions." FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>


                            <Border Grid.Row="1" Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="25">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>


                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,15,15">
                                        <TextBlock Text="Memory Limit" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,2"/>
                                        <TextBlock Text="Limits memory allocated to WSL, e.g. 4GB or 8GB" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,5"/>
                                        <TextBox x:Name="TxtWslMemory" FontSize="14" Height="40" VerticalContentAlignment="Center"/>
                                    </StackPanel>


                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="15,0,0,15">
                                        <TextBlock Text="Virtual Processors" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,2"/>
                                        <TextBlock Text="Number of CPU cores allocated, e.g. 2 or 4" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,5"/>
                                        <TextBox x:Name="TxtWslProcessors" FontSize="14" Height="40" VerticalContentAlignment="Center"/>
                                    </StackPanel>


                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,10,15,20">
                                        <TextBlock Text="Swap File Size" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,2"/>
                                        <TextBlock Text="Size of virtual memory swap space, e.g. 2GB" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,5"/>
                                        <TextBox x:Name="TxtWslSwap" FontSize="14" Height="40" VerticalContentAlignment="Center"/>
                                    </StackPanel>


                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="15,10,0,20">
                                        <TextBlock Text="Features and Networking" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,5"/>
                                        <CheckBox x:Name="ChkLocalhostForwarding" Content="Enable Localhost Port Forwarding" Margin="0,0,0,8"/>
                                        <CheckBox x:Name="ChkGuiApps" Content="Enable GUI Application Support (WSLg)" Margin="0,0,0,8"/>
                                        <CheckBox x:Name="ChkNestedVirtualization" Content="Enable Nested Virtualization" Margin="0,0,0,8"/>
                                        <CheckBox x:Name="ChkDnsTunneling" Content="Enable DNS Tunneling (Experimental)"/>
                                    </StackPanel>


                                    <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#1E3A8A" BorderBrush="#3B82F6" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,20">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Path Grid.Column="0" Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"
                                                  Fill="#93C5FD" Width="18" Height="18" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <TextBlock Grid.Column="1" Text="Tip: After saving configuration changes, you must restart the WSL subsystem completely by clicking the Shutdown button (Power icon at the bottom of the sidebar) for settings to take effect." Foreground="#BFDBFE" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>


                                    <Button Grid.Row="3" Grid.ColumnSpan="2" Content="Save WSL Engine Settings" Style="{StaticResource PrimaryButtonStyle}" Height="45" FontSize="15" Click="BtnSaveSettings_Click"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </TabItem>


                <TabItem>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid Margin="25,10,25,25">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>


                            <Border Grid.Row="0" Margin="0,0,0,15" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="0,0,0,10">
                                <StackPanel>
                                    <TextBlock Text="WSL DOCTOR &amp; ENVIRONMENT SETUP" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AccentLightBrush}"/>
                                    <TextBlock Text="Configure System Requirements" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,0"/>
                                    <TextBlock Text="If your environment is missing dependencies or fails to boot distros (e.g. error 0x80370102), use this section to install them. Note: Windows optional features require Administrator (UAC) elevation." FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>


                            <Border Grid.Row="1" Background="{StaticResource CardBgBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="25">
                                <StackPanel xmlns:sys="clr-namespace:System;assembly=mscorlib">

                                    <Grid Margin="0,0,0,25">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                            <TextBlock Text="1. Enable Windows Subsystem for Linux" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,2"/>
                                            <TextBlock Text="Enables the core Windows Subsystem for Linux (WSL) optional operating system feature." Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Enable WSL Feature" Style="{StaticResource PrimaryButtonStyle}" Height="35" Width="180" Click="BtnEnableWsl_Click"/>
                                    </Grid>


                                    <Grid Margin="0,0,0,25">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                            <TextBlock Text="2. Enable Virtual Machine Platform" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,2"/>
                                            <TextBlock Text="Enables virtualization platform component. Required to run WSL 2. Requires CPU Virtualization enabled in BIOS." Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Enable VM Platform" Style="{StaticResource PrimaryButtonStyle}" Height="35" Width="180" Click="BtnEnableVmPlatform_Click"/>
                                    </Grid>


                                    <Grid Margin="0,0,0,25">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                            <TextBlock Text="3. Choose Default WSL Version" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,2"/>
                                            <TextBlock Text="Set default version for newly installed distros. Switch to WSL 1 if Virtualization/BIOS platform is unavailable." Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="Set to WSL 1" Style="{StaticResource SecondaryButtonStyle}" Height="35" Click="BtnSetWsl1_Click" Margin="0,0,10,0"/>
                                            <Button Content="Set to WSL 2" Style="{StaticResource PrimaryButtonStyle}" Height="35" Click="BtnSetWsl2_Click"/>
                                        </StackPanel>
                                    </Grid>


                                    <Grid Margin="0,0,0,25">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                            <TextBlock Text="4. Update WSL Kernel Package" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,2"/>
                                            <TextBlock Text="Downloads and updates the Linux kernel package for the WSL engine to the latest official version." Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Update WSL Kernel" Style="{StaticResource SecondaryButtonStyle}" Height="35" Width="180" Click="BtnWslUpdate_Click"/>
                                    </Grid>


                                    <Border Background="#2A1616" BorderBrush="{StaticResource DangerBrush}" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,10,0,0">
                                        <StackPanel>
                                            <TextBlock Text="ðŸ’¡ Virtualization Issues Troubleshooting Checklist:" Foreground="#FCA5A5" FontWeight="Bold" FontSize="13" Margin="0,0,0,5"/>
                                            <TextBlock Text="â€¢ If your bios configuration blocks Virtual Machine Platform, use Step 3 to Set to WSL 1, and reinstall." Foreground="#FECACA" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,3"/>
                                            <TextBlock Text="â€¢ Ensure CPU Virtualization is set to Enabled in your PC's UEFI/BIOS configuration settings (SVM/SVM Mode for AMD, or VT-x/VMX for Intel)." Foreground="#FECACA" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,3"/>
                                            <TextBlock Text="â€¢ Remember to restart your Windows machine after enabling WSL or Virtual Machine Platform features!" Foreground="#FECACA" FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
